# Development Dockerfile
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Prod dependencies
COPY requirements.prod.txt .
RUN pip install -r requirements.prod.txt

# Dev-only dependencies
COPY requirements.dev.txt .
RUN pip install -r requirements.dev.txt \
    && pip install "watchdog[watchmedo]"

# Extra tools for dev
RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends perl git graphviz curl \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL https://raw.githubusercontent.com/brendangregg/FlameGraph/master/flamegraph.pl \
    -o /usr/local/bin/flamegraph.pl \
    && chmod +x /usr/local/bin/flamegraph.pl

# Expose API and Streamlit ports
EXPOSE 8010 8011 8501

# CMD to run Streamlit
CMD ["streamlit", "run", "src/main.py", "--server.address=0.0.0.0", "--server.port=8501"]